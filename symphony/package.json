{
  "name": "mc-symphony",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Long-running harness that polls Linear and dispatches Claude Code sessions per issue. Implements the OpenAI Symphony spec, swapping Codex for Claude.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "tsx src/main.ts",
    "dev": "tsx watch src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@linear/sdk": "^39.0.0",
    "liquidjs": "^10.21.0",
    "yaml": "^2.8.3",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.5"
  }
}
